generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("CANDIDATE") // CANDIDATE, HEADHUNTER, HIRING_MANAGER, ADMIN
  createdAt    DateTime @default(now())

  candidateProfile  CandidateProfile?
  headhunterProfile HeadhunterProfile?
  company           Company?            @relation(fields: [companyId], references: [id])
  companyId         String?
  createdRoles      JobRole[]           @relation("CreatedByHM")
  sentMessages      Message[]           @relation("SentMessages")
  receivedMessages  Message[]           @relation("ReceivedMessages")
}

model Company {
  id                String    @id @default(cuid())
  name              String
  industry          String?
  cultureAttributes String?
  members           User[]
  roles             JobRole[] @relation("CompanyRoles")
  subscription      Subscription? @relation("CompanySubscription")
}

model JobRole {
  id              String   @id @default(cuid())
  title           String
  description     String
  hardSkills      String   @default("[]")
  softSkills      String   @default("[]")
  weights         String   @default("{\"hardSkills\":40,\"softSkills\":25,\"experience\":25,\"education\":10}")
  threshold       Int      @default(70)
  status          String   @default("DRAFT") // DRAFT, PUBLISHED, CLOSED
  roleType        String   @default("PERMANENT") // PERMANENT, CONTRACT_SHORT, CONTRACT_MEDIUM, CONTRACT_LONG
  bounty          Int?     // Custom headhunter bounty in cents (overrides default split)
  company         Company  @relation("CompanyRoles", fields: [companyId], references: [id])
  companyId       String
  createdBy       User     @relation("CreatedByHM", fields: [createdById], references: [id])
  createdById     String

  claimedBy   HeadhunterProfile? @relation(fields: [claimedById], references: [id])
  claimedById String?

  applications Application[]
  milestones   MilestoneFee[]
  createdAt    DateTime        @default(now())
}

model CandidateProfile {
  id          String @id @default(cuid())
  user        User   @relation(fields: [userId], references: [id])
  userId      String @unique
  bio         String?
  resumeUrl   String?
  skills      String @default("[]")
  experience  String @default("[]")
  education   String @default("[]")
  preferences String @default("{}")
  visibility  String @default("ACTIVE") // ACTIVE, PASSIVE, HIDDEN

  applications  Application[]
  skillHistory  SkillSnapshot[]
}

model HeadhunterProfile {
  id                    String @id @default(cuid())
  user                  User   @relation(fields: [userId], references: [id])
  userId                String @unique
  domainSpecializations String @default("[]")
  performanceMetrics    String @default("{}")

  claimedRoles JobRole[]
  applications Application[]
  subscription Subscription? @relation("HeadhunterSubscription")
  placements   Placement[]
}

model Application {
  id             String  @id @default(cuid())
  candidate      CandidateProfile @relation(fields: [candidateId], references: [id])
  candidateId    String
  role           JobRole @relation(fields: [roleId], references: [id])
  roleId         String
  headhunter     HeadhunterProfile? @relation(fields: [headhunterId], references: [id])
  headhunterId   String?
  matchScore     Int?
  scoreBreakdown String?
  stage          String  @default("APPLIED") // APPLIED, SCREENING, SHORTLISTED, INTERVIEW, OFFER, HIRED, REJECTED
  hmConfirmed    Boolean @default(false)
  candidateConfirmed Boolean @default(false)
  auditLog       String  @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  skillGaps  SkillGap[]
  placement  Placement?

  @@unique([candidateId, roleId])
}

model SkillGap {
  id              String      @id @default(cuid())
  application     Application @relation(fields: [applicationId], references: [id])
  applicationId   String
  skill           String
  category        String      // HARD, SOFT
  currentLevel    Int
  requiredLevel   Int
  status          String      // MET, PARTIAL, MISSING
  recommendations String      @default("[]")
}

model Subscription {
  id                   String             @id @default(cuid())
  plan                 String             // HM: STARTER, PROFESSIONAL, ENTERPRISE; HH: FREE, PRO
  billingPeriod        String             @default("MONTHLY") // MONTHLY, YEARLY
  status               String             @default("ACTIVE") // ACTIVE, CANCELLED, PAST_DUE
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime?
  company              Company?           @relation("CompanySubscription", fields: [companyId], references: [id])
  companyId            String?            @unique
  headhunterProfile    HeadhunterProfile? @relation("HeadhunterSubscription", fields: [headhunterProfileId], references: [id])
  headhunterProfileId  String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// --- Milestone billing ---

model MilestoneFee {
  id          String   @id @default(cuid())
  role        JobRole  @relation(fields: [roleId], references: [id])
  roleId      String
  milestone   String   // SHORTLIST, HIRE
  amountCents Int      // Configurable fee in cents
  currency    String   @default("USD")
  createdAt   DateTime @default(now())

  @@unique([roleId, milestone])
}

model MilestoneCharge {
  id          String   @id @default(cuid())
  roleId      String
  milestone   String   // SHORTLIST, HIRE
  amountCents Int
  currency    String   @default("USD")
  status      String   @default("PENDING") // PENDING, PAID, WAIVED
  paidAt      DateTime?
  createdAt   DateTime @default(now())
}

// --- Placement tracking (headhunter attribution) ---

model Placement {
  id              String   @id @default(cuid())
  application     Application @relation(fields: [applicationId], references: [id])
  applicationId   String   @unique
  headhunter      HeadhunterProfile @relation(fields: [headhunterId], references: [id])
  headhunterId    String
  commissionCents Int      // Headhunter's share
  platformCents   Int      // Platform's share
  status          String   @default("PENDING") // PENDING, PAID
  confirmedAt     DateTime?
  paidAt          DateTime?
  createdAt       DateTime @default(now())
}

// --- In-platform messaging ---

model Message {
  id         String   @id @default(cuid())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId String
  subject    String?
  body       String
  readAt     DateTime?
  createdAt  DateTime @default(now())
}

// --- Candidate skill history (retention / career trajectory) ---

model SkillSnapshot {
  id          String           @id @default(cuid())
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  candidateId String
  skills      String           // JSON snapshot of skills at this point in time
  matchScores String           @default("{}") // JSON: { roleId: score } for roles available at snapshot time
  createdAt   DateTime         @default(now())
}

// --- Platform fee configuration ---

model PlatformConfig {
  id                    String @id @default(cuid())
  shortlistFeeCents     Int    @default(4900)  // $49 default
  hireFeePermanentCents Int    @default(99900) // $999 default
  hireFeeContractShort  Int    @default(19900) // $199 for <3mo contracts
  hireFeeContractMedium Int    @default(39900) // $399 for 3-6mo contracts
  hireFeeContractLong   Int    @default(69900) // $699 for 6mo+ contracts
  defaultHHSplitPct     Int    @default(60)    // Headhunter gets 60% of hire fee
  attributionWindowDays Int    @default(365)   // 12-month sourcing credit
}
