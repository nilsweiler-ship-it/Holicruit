// Holicruit data model — built around the fit model and opt-in matching.
// SQLite: no native enums or Json scalar, so those are Strings (JSON-encoded
// where noted). Helpers in src/lib/db serialize/parse them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Identity ──────────────────────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  initials     String
  // JSON array of hats the user holds: "candidate" | "hiring_manager" | "recruiter" | "provider"
  roles        String  @default("[\"candidate\"]")
  createdAt    DateTime @default(now())

  candidate     CandidateProfile?
  provider      Provider?
  companies     Company[]
  intros        RecruiterIntro[]
  subscriptions Subscription[]
  sentMessages  Message[]
}

// ── Candidate ─────────────────────────────────────────────────────────────

model CandidateProfile {
  id                String  @id @default(cuid())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String  @unique
  headline          String
  industry          String
  completeness      Int     @default(40)
  scenarioCompleted Boolean @default(false)

  hardSkills   HardSkill[]
  softSkills   SoftSkillScore[]
  endorsements Endorsement[]
  matches      Match[]
  enrollments  Enrollment[]
  scenarioRuns ScenarioResult[]
}

model HardSkill {
  id        String           @id @default(cuid())
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  name      String
  verified  Boolean          @default(false)

  @@unique([profileId, name])
}

model SoftSkillScore {
  id        String           @id @default(cuid())
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  name      String
  level     Int

  @@unique([profileId, name])
}

model Endorsement {
  id              String           @id @default(cuid())
  profile         CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId       String
  skill           String
  endorserName    String
  endorserInitials String
  endorserHeadline String
  relationship    String
  createdAt       DateTime         @default(now())
}

model ScenarioResult {
  id        String           @id @default(cuid())
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  // JSON array of { name, level }
  scores    String
  createdAt DateTime         @default(now())
}

// ── Roles / openings ──────────────────────────────────────────────────────

model Company {
  id       String    @id @default(cuid())
  name     String
  location String
  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId  String
  openings Opening[]
}

model Opening {
  id                  String  @id @default(cuid())
  title               String
  industry            String
  company             Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId           String
  location            String
  salaryMin           Int?
  salaryMax           Int?
  currency            String  @default("€")
  hiringManagerName   String
  hiringManagerHeadline String
  hiringManagerInitials String
  // JSON arrays of required skill names
  requiredHard        String  @default("[]")
  requiredSoft        String  @default("[]")
  matches             Match[]
}

// ── The match (fit model) ─────────────────────────────────────────────────

model Match {
  id            String           @id @default(cuid())
  candidate     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId   String
  opening       Opening          @relation(fields: [openingId], references: [id], onDelete: Cascade)
  openingId     String

  hardFit       Int
  softFit       Int
  mutualFit     Int
  verified      Boolean          @default(false)
  // JSON array of { skill, type, severity }
  gaps          String           @default("[]")
  candidateRank Int?
  poolSize      Int?

  // new | talking | offer | closed
  stage         String           @default("new")
  candidateOptIn Boolean         @default(false)
  managerOptIn  Boolean          @default(false)
  saved         Boolean          @default(false)
  createdAt     DateTime         @default(now())

  thread       Thread?
  growthReport GrowthReport?
  feedback     FeedbackDraft?

  @@unique([candidateId, openingId])
}

model Thread {
  id        String     @id @default(cuid())
  match     Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String     @unique
  createdAt DateTime   @default(now())
  messages  Message[]
  interview Interview?
}

model Message {
  id        String   @id @default(cuid())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  from      User?    @relation(fields: [fromUserId], references: [id])
  fromUserId String?
  // Fallback label when the sender isn't a real user row (seed/HM persona)
  fromName  String
  text      String
  createdAt DateTime @default(now())
}

model Interview {
  id                String  @id @default(cuid())
  thread            Thread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId          String  @unique
  whenText          String
  medium            String  @default("video")
  scoreSheetAttached Boolean @default(false)
}

model GrowthReport {
  id                  String @id @default(cuid())
  match               Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId             String @unique
  roleTitle           String
  company             String
  hardYou             Int
  hardBar             Int
  softYou             Int
  softBar             Int
  primaryGapSkill     String
  primaryGapType      String
  rolesClearedIfClosed Int
  matchingProgramCount Int
  createdAt           DateTime @default(now())
}

model FeedbackDraft {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String   @unique
  body      String
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Recruiter ─────────────────────────────────────────────────────────────

model RecruiterIntro {
  id            String @id @default(cuid())
  recruiter     User   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  recruiterId   String
  candidateName String
  roleTitle     String
  company       String
  valueNote     String
  // talking | interview | offer | hired
  stage         String @default("talking")
}

// ── Training provider + marketplace ───────────────────────────────────────

model Provider {
  id       String    @id @default(cuid())
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String    @unique
  name     String
  kind     String
  headline String
  initials String
  programs Program[]
}

model Program {
  id          String   @id @default(cuid())
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId  String
  title       String
  format      String
  credential  String?
  // JSON array of tag strings
  tags        String   @default("[]")
  closesGap   String
  gapType     String
  sponsored   Boolean  @default(false)
  enrollments Int      @default(0)
  completions Int      @default(0)
  reMatches   Int      @default(0)

  enrollmentRows Enrollment[]
}

model Enrollment {
  id          String           @id @default(cuid())
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId   String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId String
  // enrolled | completed
  status      String           @default("enrolled")
  createdAt   DateTime         @default(now())

  @@unique([programId, candidateId])
}

// ── Billing ───────────────────────────────────────────────────────────────

model Subscription {
  id                   String  @id @default(cuid())
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String
  // which hat the plan is for: hiring_manager | provider
  hat                  String
  // plan key, e.g. hm-team, hm-scale, provider-partner
  plan                 String
  // active | trialing | canceled | incomplete
  status               String  @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?

  @@unique([userId, hat])
}
