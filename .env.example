# Copy to .env and fill in. See DEPLOY.md for hosting.

# Database. SQLite for local/dev; a file path on a persistent disk in prod,
# or a Postgres URL if deploying serverless (see DEPLOY.md).
DATABASE_URL=file:./dev.db

# NextAuth v5 — generate one with: npx auth secret
AUTH_SECRET=

# The app's public URL (used for links/callbacks). Local default below.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (TEST mode). Leave blank to run billing in stub mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
